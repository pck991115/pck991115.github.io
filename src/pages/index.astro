---
import { getCollection } from "astro:content";
import { ArrowRight, BookOpen, CheckCircle, Circle, NotePencil } from "@phosphor-icons/react";
import KnowledgeOrbit from "../components/KnowledgeOrbit.jsx";
import Layout from "../layouts/Layout.astro";
import { currentWork, projects, themes } from "../data/site";

const notes = (await getCollection("notes"))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", {
    month: "2-digit",
    day: "2-digit",
  }).format(date);
---

<Layout>
  <KnowledgeOrbit client:load />
  <div class="home-shell">
    <header class="home-hero">
      <div>
        <p class="eyebrow">个人知识与作品集</p>
        <h1>欢迎来到我的知识主页</h1>
        <p class="home-hero__intro">记录问题、实践、复盘，也记录仍在生长的答案。</p>
      </div>

      <aside class="status-panel" aria-label="当前状态">
        <h2>此刻</h2>
        <ul>
          <li><CheckCircle size={19} /><span>持续学习与构建中</span></li>
          <li><BookOpen size={19} /><span>本周学习 6 篇笔记</span></li>
          <li><NotePencil size={19} /><span>正在推进 2 个项目</span></li>
        </ul>
      </aside>
    </header>

    <section class="home-section topics-section">
      <div class="section-heading">
        <h2>探索主题</h2>
      </div>
      <div class="topic-grid">
        {themes.map((theme) => (
          <a href={`/notes/?theme=${encodeURIComponent(theme.name)}`} class="topic-link">
            <span class="topic-link__index">{theme.index}</span>
            <strong>{theme.name}</strong>
            <small>{theme.count} 篇</small>
            <span class="sr-only">{theme.description}</span>
          </a>
        ))}
      </div>
    </section>

    <div class="home-columns home-section">
      <section class="updates-panel">
        <div class="section-heading">
          <h2>最近更新</h2>
        </div>
        <div class="update-list">
          {notes.slice(0, 5).map((note) => (
            <a href={`/notes/${note.id}/`} class="update-row">
              <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
              <span>{note.data.title}</span>
            </a>
          ))}
        </div>
        <a class="text-link" href="/notes/">
          查看全部 <ArrowRight size={16} />
        </a>
      </section>

      <section class="current-panel">
        <div class="section-heading">
          <h2>正在进行</h2>
        </div>
        <div class="current-project">
          <div class="current-project__title">
            <Circle size={9} weight="fill" aria-hidden="true" />
            <strong>{currentWork.title}</strong>
          </div>
          <p>{currentWork.description}</p>
          <div class="progress-row">
            <span>进度：{currentWork.progress}%</span>
            <div class="progress-track" aria-label={`项目进度 ${currentWork.progress}%`}>
              <span style={`width: ${currentWork.progress}%`}></span>
            </div>
          </div>
          <a class="text-link" href="/now/">
            查看全部 <ArrowRight size={16} />
          </a>
        </div>
      </section>
    </div>

    <section class="home-section projects-preview">
      <div class="section-heading">
        <h2>公开项目</h2>
      </div>
      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-preview">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <small>{project.role}</small>
            <a class="text-link" href={project.href}>
              查看项目 <ArrowRight size={16} />
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</Layout>
