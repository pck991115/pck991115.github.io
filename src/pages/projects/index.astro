---
import { ArrowUpRight } from "@phosphor-icons/react";
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/site";
---

<Layout title="工作与项目｜庞成康">
  <div class="page-shell">
    <header class="page-header">
      <p class="eyebrow">Selected work</p>
      <h1>工作与项目</h1>
      <p>只展示可以公开的案例，重点记录问题、过程、我的职责与最终结果。</p>
    </header>

    <div class="case-list">
      {projects.map((project, index) => (
        <article class="case-study" id={project.href.split("#")[1]}>
          <span class="case-study__index">0{index + 1}</span>
          <div>
            <h2>{project.title}</h2>
            <p>{project.description}</p>
          </div>
          <dl>
            <div><dt>我的职责</dt><dd>{project.role}</dd></div>
            <div><dt>技术与工具</dt><dd>{project.stack}</dd></div>
          </dl>
          <a href="mailto:hello@example.com" aria-label={`了解${project.title}`}>
            了解更多 <ArrowUpRight size={17} />
          </a>
        </article>
      ))}
    </div>
  </div>
</Layout>
