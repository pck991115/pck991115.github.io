---
import { getCollection } from "astro:content";
import NotesExplorer from "../../components/NotesExplorer.jsx";
import Layout from "../../layouts/Layout.astro";

const notes = (await getCollection("notes"))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((note) => ({
    title: note.data.title,
    description: note.data.description,
    theme: note.data.theme,
    tags: note.data.tags,
    date: new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    }).format(note.data.date),
    isoDate: note.data.date.toISOString(),
    readingTime: note.data.readingTime,
    href: `/notes/${note.id}/`,
  }));
---

<Layout title="学习笔记｜庞成康">
  <div class="page-shell">
    <header class="page-header">
      <p class="eyebrow">Learning notes</p>
      <h1>学习笔记</h1>
      <p>把新知识放进自己的语境里，再通过实践和复盘让它留下来。</p>
    </header>
    <NotesExplorer client:load notes={notes} />
  </div>
</Layout>
